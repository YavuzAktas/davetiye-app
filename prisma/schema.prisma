generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  emailVerified DateTime?
  image         String?
  plan          String      @default("free")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  davetiyeler   Davetiye[]
  accounts  Account[]
  sessions  Session[]
  odemeTokenlar OdemeToken[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Davetiye {
  id           String    @id @default(cuid())
  slug         String    @unique
  baslik       String
  etkinlikTur  String
  tarih        DateTime?
  mekan        String?
  mesaj        String?
  sablon       String    @default("klasik")
  ozelRenk     String?
  font         String    @default("font-sans")
  muzik        String?
  aktif        Boolean   @default(true)
  goruntulenme Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rsvplar      RSVP[]
  davetliler Davetli[]
}

model RSVP {
  id          String   @id @default(cuid())
  ad          String
  email       String?
  telefon     String?
  katilim     Boolean
  kisiSayisi  Int      @default(1)
  not         String?
  createdAt   DateTime @default(now())
  davetiyeId  String
  davetiye    Davetiye @relation(fields: [davetiyeId], references: [id], onDelete: Cascade)
}

model OdemeToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  planId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Davetli {
  id         String   @id @default(cuid())
  ad         String
  telefon    String?
  email      String?
  notlar     String?
  createdAt  DateTime @default(now())
  davetiyeId String
  davetiye   Davetiye @relation(fields: [davetiyeId], references: [id], onDelete: Cascade)
}