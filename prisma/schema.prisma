generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  plan          String       @default("free")
  password      String?
  kvkkOnay      Boolean      @default(false)
  kvkkOnayTarih DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  davetiyeler   Davetiye[]
  odemeTokenlar OdemeToken[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Davetiye {
  id           String    @id @default(cuid())
  slug         String    @unique
  baslik       String
  etkinlikTur  String
  tarih        DateTime?
  mekan        String?
  mesaj        String?
  sablon       String    @default("klasik")
  muzik        String?
  aktif        Boolean   @default(true)
  goruntulenme Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userId       String
  font         String    @default("font-sans")
  ozelRenk     String?
  kisi1        String?
  kisi2        String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  davetliler   Davetli[]
  rsvplar      RSVP[]

  @@index([userId])
  @@index([aktif])
}

model RSVP {
  id         String   @id @default(cuid())
  ad         String
  email      String?
  telefon    String?
  katilim    Boolean
  kisiSayisi Int      @default(1)
  mesaj      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  davetiyeId String
  davetiye   Davetiye @relation(fields: [davetiyeId], references: [id], onDelete: Cascade)

  @@index([davetiyeId])
}

model OdemeToken {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  planId     String
  kullanildi Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Davetli {
  id         String   @id @default(cuid())
  ad         String
  telefon    String?
  email      String?
  notlar     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  davetiyeId String
  davetiye   Davetiye @relation(fields: [davetiyeId], references: [id], onDelete: Cascade)

  @@index([davetiyeId])
}
